{
  "name": "nestjs-playground",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start api --watch",
    "start:dev": "nest start api --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/nestjs-playground/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run --no-file-parallelism",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --single-thread",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:ci": "vitest run --coverage",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/.bin/typeorm -d scripts/migration/MigrationConfig.ts",
    "migrate": "yarn typeorm migration:run",
    "migration-generate": "yarn typeorm migration:generate ./scripts/migration/Migration --pretty && yarn eslint --fix ./scripts/migration",
    "swagger-generate": "vitest run swagger.generator.spec.ts",
    "release": "./scripts/github/release.sh"
  },
  "dependencies": {
    "@aws-crypto/client-node": "^4.0.0",
    "@aws-sdk/client-s3": "^3.354.0",
    "@aws-sdk/client-ses": "^3.410.0",
    "@aws-sdk/client-sns": "^3.354.0",
    "@js-joda/core": "^5.5.2",
    "@nestjs/common": "^9.0.0",
    "@nestjs/config": "^2.3.1",
    "@nestjs/core": "^9.0.0",
    "@nestjs/event-emitter": "^2.0.0",
    "@nestjs/platform-express": "^9.0.0",
    "@nestjs/swagger": "^6.2.1",
    "@nestjs/typeorm": "^9.0.1",
    "@types/js-yaml": "^4.0.5",
    "@types/mustache": "^4.2.3",
    "@types/node-fetch": "^2.6.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cls-rtracer": "^2.6.3",
    "got": "^11.8.2",
    "ioredis": "^5.9.2",
    "js-yaml": "^4.1.0",
    "mustache": "^4.2.0",
    "mysql2": "^3.20.0",
    "node-fetch": "2",
    "node-json-db": "^2.3.0",
    "openai": "^4.12.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^3.7.107",
    "pg": "^8.9.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.2.0",
    "typeorm": "^0.3.12",
    "typeorm-naming-strategies": "^4.1.0",
    "winston": "^3.8.2"
  },
  "devDependencies": {
    "@faker-js/faker": "^7.6.0",
    "@nestjs/cli": "^9.0.0",
    "@nestjs/schematics": "^9.0.0",
    "@nestjs/testing": "^9.0.0",
    "@swc/core": "^1.15.18",
    "@types/express": "^4.17.13",
    "@types/node": "18.11.18",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.0.1",
    "eslint-config-async": "^2.0.2",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-vitest": "^0.5.4",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.2",
    "nock": "^13.3.1",
    "pg-mem": "^2.6.13",
    "prettier": "^2.3.2",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-loader": "^9.2.3",
    "ts-morph": "^18.0.0",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "4.1.1",
    "typescript": "^4.7.4",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0",
    "vitest-mock-extended": "^3.1.0"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  }
}
